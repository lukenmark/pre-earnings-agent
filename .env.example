# Anthropic API
ANTHROPIC_API_KEY=your_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_CHAT_ID=your_group_chat_id_here

# Database
DATABASE_URL=sqlite:///./research.db

# Optional: override models
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Optional: data overrides
FINVIZ_SCREEN_LIMIT=20

# Data providers
NEWS_PROVIDER=yfinance
OPTIONS_PROVIDER=estimated
INDUSTRY_PROVIDER=yfinance

# Dashboard
DASHBOARD_PASSWORD=your_shared_password_here
